# Backend environment variables (copy to Render / your host)

# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.ibj2zx9.mongodb.net/ddjc?retryWrites=true&w=majority&appName=Cluster0

# JSON Web Token secret (use a long random string in production)
JWT_SECRET=your_strong_secret_here

# Port (Render sets this automatically)
PORT=5000

# Deployed frontend origin (GitHub Pages URL), used for CORS
# Example: https://saksham9065.github.io
CLIENT_ORIGIN=https://saksham9065.github.io

# Email (nodemailer) credentials
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
